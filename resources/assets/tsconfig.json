{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "strict": true,
    "noImplicitAny": false,
    "module": "esnext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowJs": true,
    "paths": {
      "@/*": ["js/*"]
    }
  },
  "include": ["js/**/*", "../../node_modules/vitest/globals.d.ts"],
  "exclude": ["js/__tests__/**/*"]
}
