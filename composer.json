{
  "name": "koel/koel",
  "description": "Audio streaming solution that works.",
  "license": "MIT",
  "type": "project",
  "keywords": [
    "audio",
    "stream",
    "mp3"
  ],
  "require": {
    "php": ">=8.3",
    "ext-exif": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "algolia/algoliasearch-client-php": "^3.3",
    "daverandom/resume": "^0.0.3",
    "enshrined/svg-sanitize": "^0.22.0",
    "ezyang/htmlpurifier": "^4.18",
    "fakerphp/faker": "^1.24",
    "fileeye/mimemap": "^2.2",
    "guzzlehttp/guzzle": "^7.2",
    "http-interop/http-factory-guzzle": "^1.2",
    "intervention/image-laravel": "^1.5",
    "james-heinrich/getid3": "^1.9",
    "jaybizzle/crawler-detect": "^1.3",
    "jwilsson/spotify-web-api-php": "^5.2",
    "koel/dotenv-editor": "^2.2",
    "laravel/ai": "^0.2.6",
    "laravel/framework": "^12.0",
    "laravel/helpers": "^1.7",
    "laravel/nightwatch": "^1.13",
    "laravel/prompts": "^0.3.6",
    "laravel/sanctum": "^4.0",
    "laravel/scout": "^10.0",
    "laravel/socialite": "^5.12",
    "laravel/tinker": "^2.10",
    "laravel/ui": "^4.5",
    "league/flysystem-aws-s3-v3": "^3.0",
    "league/flysystem-sftp-v3": "^3.0",
    "lstrojny/functional-php": "^1.14",
    "meilisearch/meilisearch-php": "^0.24.0",
    "nunomaduro/collision": "^8.8",
    "owen-it/laravel-auditing": "^14.0",
    "paragonie/sodium_compat": "^1.6",
    "phanan/poddle": "^1.2",
    "predis/predis": "^1.0",
    "pusher/pusher-php-server": "^7.2",
    "saloonphp/laravel-plugin": "^3.0",
    "saloonphp/saloon": "^3.8",
    "spatie/flysystem-dropbox": "^3.0",
    "spatie/laravel-permission": "^6.21",
    "spatie/laravel-ray": "^1.36",
    "teamtnt/laravel-scout-tntsearch-driver": "^15.0",
    "tiben/crontab-manager": "*",
    "webmozart/assert": "^1.10"
  },
  "require-dev": {
    "carthage-software/mago": "^1.8.0",
    "ergebnis/composer-normalize": "^2.50",
    "larastan/larastan": "^3.7",
    "laravel/boost": "^1.0",
    "mockery/mockery": "^1.0",
    "opcodesio/log-viewer": "^3.19",
    "phlak/semver": "^5.0",
    "php-mock/php-mock-mockery": "^1.3",
    "phpunit/phpunit": "^11.0",
    "roave/security-advisories": "dev-latest"
  },
  "suggest": {
    "ext-zip": "Allow downloading multiple songs as Zip archives"
  },
  "minimum-stability": "stable",
  "prefer-stable": false,
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "classmap": [
      "database"
    ],
    "files": [
      "app/Helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Database\\Factories\\": "database/factories/",
      "Tests\\": "tests/"
    },
    "classmap": [
      "tests/TestCase.php"
    ],
    "files": [
      "tests/Helpers.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "carthage-software/mago": true,
      "ergebnis/composer-normalize": true,
      "php-http/discovery": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.3.0"
    },
    "preferred-install": "dist"
  },
  "scripts": {
    "post-install-cmd": [
      "@php artisan clear-compiled",
      "@php artisan cache:clear",
      "@php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\"",
      "@php -r \"if (!file_exists('./public/.htaccess')) copy('.htaccess.example', './public/.htaccess');\""
    ],
    "pre-update-cmd": [
      "@php artisan clear-compiled"
    ],
    "post-update-cmd": [
      "@php artisan cache:clear",
      "@php artisan boost:update --ansi"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover"
    ],
    "post-root-package-install": [
      "@php -r \"copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate"
    ],
    "analyze": "phpstan analyse --memory-limit 1G --configuration phpstan.neon.dist --ansi",
    "coverage": "@php artisan test --coverage-clover=coverage.xml",
    "cs": "mago format --check",
    "cs:fix": "mago format",
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -k -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"vite\" --names=server,queue,vite --restart-tries=3"
    ],
    "koel:init": "@php scripts/koel-init.php",
    "lint": "mago lint",
    "test": "@php artisan test"
  }
}
